# apps/brain — variables de entorno (panel admin/CFO, app.enverde.app + brain Raíz)
# Los valores reales viven en Vercel (proyecto `brain`) y en .env.local (nunca en git).
# Inventario de la auditoría 2026-07-03 (docs/auditoria-fable-5/, backlog #8).

# ── Firebase Admin SDK (server) ──────────────────────────────────
# JSON completo del service account, en una línea. Alternativa: ruta de archivo
# en GOOGLE_APPLICATION_CREDENTIALS (usada por los scripts CLI en local).
FIREBASE_ADMIN_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Firebase cliente (públicas, van al bundle) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── IA (Claude) ──────────────────────────────────────────────────
# Clave de plataforma: facturas-IA y CFO summaries. Los cafés enverde free la
# usan bajo cupo mensual; BYOK per-org (cifrada con SECRETS_ENC_KEY) la sustituye.
ANTHROPIC_API_KEY=
# Cupo de llamadas IA/mes por org enverde sin clave propia (default 40).
ENVERDE_FREE_AI_CALLS_PER_MONTH=
# Clave maestra AES-GCM para el sobre BYOK (lib/secrets/crypto.ts). NO rotar
# sin plan: invalida las claves per-org ya cifradas.
SECRETS_ENC_KEY=

# ── Stripe (bonos exam-pass de Raíz — LIVE) ──────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# true SOLO para probar ciclo compra→canje sin cobrar (rutas exam-pass/test/*).
ENABLE_EXAM_PASS_TEST_MODE=

# ── Integraciones entre servicios ────────────────────────────────
# Secreto compartido con el marketplace para /api/enverde/provision (alta de cafés).
ENVERDE_PROVISION_SECRET=
# Secreto que el marketplace usa contra endpoints internos del brain.
MARKETPLACE_API_SECRET=
# Auth del cron de Vercel (/api/cron/expire-redemptions).
CRON_SECRET=
# Snapshot demo de treasury para el funnel público (/api/demo/treasury-snapshot).
DEMO_SNAPSHOT_SECRET=
# API keys aceptadas en /api/public/* (extract-invoice).
PUBLIC_API_KEYS=
# Proxy al motor de staging (/api/staging/[...path]) — uso incierto, ver auditoría 02 §brain.
STAGING_ENGINE_URL=
STAGING_API_TOKEN=

# ── URLs entre apps ──────────────────────────────────────────────
# URL pública del POS (handoff "Abrir TPV" desde el hub).
NEXT_PUBLIC_POS_URL=
