# apps/app — variables de entorno (PWA cliente de Raíz: fidelidad, pedidos, bonos)
# Los valores reales viven en Vercel (proyecto `app`) y en .env.local (nunca en git).
# Inventario de la auditoría 2026-07-03 (docs/auditoria-fable-5/, backlog #8).

# ── Firebase Admin SDK (server) ──────────────────────────────────
# ⚠️ Esta app usa un formato DISTINTO a pos/brain (FIREBASE_ADMIN_JSON):
# o bien el JSON completo del service account…
FIREBASE_SERVICE_ACCOUNT_JSON=
# …o bien el par email + private key. Unificar con pos/brain al rotar la key
# (auditoría 03, ALT-1).
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Firebase cliente (públicas, van al bundle) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Stripe (bonos exam-pass — LIVE) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# true SOLO en entornos de prueba del ciclo de bonos.
NEXT_PUBLIC_ENABLE_EXAM_PASS_TEST_MODE=

# ── Brain / flags ────────────────────────────────────────────────
NEXT_PUBLIC_BRAIN_API_URL=
# Flag de la migración loyalty cliente→servidor (aún leído; ver auditoría 02).
NEXT_PUBLIC_USE_SERVER_LOYALTY=
