{
  "name": "raiz-platform",
  "private": true,
  "workspaces": [
    "apps/app",
    "apps/pos",
    "apps/brain",
    "packages/shared"
  ],
  "scripts": {
    "dev:app": "npm run dev --workspace=apps/app -- -p 3000",
    "dev:pos": "npm run dev --workspace=apps/pos -- -p 3001",
    "dev:brain": "npm run dev --workspace=apps/brain -- -p 3002",
    "dev": "npm run dev:app & npm run dev:pos",
    "dev:all": "npm run dev:app & npm run dev:pos & npm run dev:brain",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "firebase": "12.9.0",
    "tinyexec": "^1.0.4"
  },
  "engines": {
    "node": ">=20.12"
  }
}
